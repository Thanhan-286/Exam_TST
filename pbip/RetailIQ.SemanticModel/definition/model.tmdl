model RetailIQ
	culture: vi-VN
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: en-US
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

annotation PBI_ProTooling = ["MCP-PBIModeling"]

ref table dim_month
ref table dim_market_region
ref table dim_category
ref table dim_product
ref table dim_customer
ref table dim_warehouse
ref table fact_sales
ref table fact_inventory
ref table plan_monthly
ref table item_moc
ref table dq_fact_sales
ref table dq_fact_inventory
ref table dq_inventory_recon
ref table audit_issues
ref table audit_rules
ref table audit_error_layer
ref table audit_waterfall
ref table audit_dq_results
ref table cleaning_scenarios

